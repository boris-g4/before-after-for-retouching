{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "before-after-for-retouching/compare",
  "version": "1.0.0",
  "title": "Before & After Comparison",
  "category": "media",
  "icon": "image-flip-horizontal",
  "description": "Compare a Before and After image with an interactive slider.",
  "keywords": ["before", "after", "comparison"],
  "textdomain": "before-after-for-retouching",
  "attributes": {
    "beforeId": {"type": "number", "default": 0},
    "afterId": {"type": "number", "default": 0},
    "beforeUrl": {"type": "string", "default": ""},
    "afterUrl": {"type": "string", "default": ""},
    "beforeSizes": {"type": "object", "default": {}},
    "afterSizes": {"type": "object", "default": {}},
    "beforeWidth": {"type": "number", "default": 0},
    "beforeHeight": {"type": "number", "default": 0},
    "afterWidth": {"type": "number", "default": 0},
    "afterHeight": {"type": "number", "default": 0},
    "ratio": {"type": "string", "default": "auto"},
    "customRatio": {"type": "string", "default": "3/2"},
    "start": {"type": "number", "default": 50},
    "fit": {"type": "string", "default": "contain"},
    "interaction": {"type": "string", "default": "hover"},
    "loading": {"type": "string", "default": "auto"},
    "imageSize": {"type": "string", "default": "full"},
    "showDivider": {"type": "boolean", "default": false},
    "showHandle": {"type": "boolean", "default": false},
    "showSlider": {"type": "boolean", "default": true},
    "showBeforeLabel": {"type": "boolean", "default": false},
    "showAfterLabel": {"type": "boolean", "default": false},
    "beforeLabel": {"type": "string", "default": ""},
    "afterLabel": {"type": "string", "default": ""},
    "lineColor": {"type": "string", "default": "#ffffff"},
    "lineWidth": {"type": "number", "default": 2},
    "handleColor": {"type": "string", "default": "#ffffff"},
    "labelColor": {"type": "string", "default": "#ffffff"},
    "labelBackground": {"type": "string", "default": "#000000"}
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "editorScript": "before-after-for-retouching-block-editor",
  "editorStyle": "before-after-for-retouching-block-editor",
  "style": "before-after-for-retouching"
}
